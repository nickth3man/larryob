#!/bin/sh
set -eu

if ! command -v uv >/dev/null 2>&1; then
  echo "pre-commit: uv is required but was not found in PATH."
  exit 1
fi

echo "pre-commit: running quality checks..."

# Auto-fix and format only staged Python files, then re-stage them
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$STAGED_PY" ]; then
  echo "$STAGED_PY" | xargs uv run ruff check --fix --quiet
  echo "$STAGED_PY" | xargs uv run ruff format --quiet
  echo "$STAGED_PY" | xargs git add
fi

# Type check (fast, whole-project scope)
uv run ty check
