#!/bin/sh
set -eu

if ! command -v uv >/dev/null 2>&1; then
  echo "pre-commit: uv is required but was not found in PATH."
  exit 1
fi

echo "pre-commit: running quality checks..."

# Auto-fix and format only staged Python files, then re-stage them
while IFS= read -r file; do
  [ -z "$file" ] && continue
  uv run ruff check --fix --quiet "$file"
  uv run ruff format --quiet "$file"
  git add "$file"
done < <(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

# Type check (fast, whole-project scope)
uv run ty check
